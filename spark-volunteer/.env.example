# =============================================================================
# .env — 星火志愿服务平台 环境变量模板
# 使用方法: copy .env.example .env → 修改真实值
# =============================================================================

# -----------------------------------------------------------------------------
# HTTPS 域名（部署前先运行 certbot-setup.sh）
# -----------------------------------------------------------------------------
DOMAIN=example.com

# -----------------------------------------------------------------------------
# MySQL 数据库
# -----------------------------------------------------------------------------
DB_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# JWT 签名密钥（生产环境务必修改为 32+ 位随机字符串）
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS

# -----------------------------------------------------------------------------
# JWT 过期时间（毫秒），默认 86400000 = 24 小时
# -----------------------------------------------------------------------------
JWT_EXPIRATION=86400000
