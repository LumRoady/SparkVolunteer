# ==================== 星火志愿服务平台 — 环境变量配置模板 ====================
# 复制此文件为 .env 并填入真实值
# 切勿将包含真实密码的 .env 文件提交到代码仓库

# 数据库密码（必填）
DB_PASSWORD=changeme

# JWT 签名密钥（必填，至少 256 位随机字符串）
# 生成命令：openssl rand -base64 64
JWT_SECRET=changeme-at-least-256-bits

# Redis 密码（如不设置密码则留空）
REDIS_PASSWORD=

# 微信小程序 AppID 和 Secret（用于模板消息通知家属）
WECHAT_APPID=your_appid
WECHAT_SECRET=your_secret
WECHAT_TEMPLATE_ID=your_template_id

# CORS 允许的来源（生产环境改为实际域名）
CORS_ALLOWED_ORIGINS=http://localhost:*

# 服务端口
SERVER_PORT=8084

# Spring Profile：dev / prod
SPRING_PROFILES_ACTIVE=prod
