# =============================================================================
# Vite 生产环境变量 — 星火管理后台
#
# 构建时由 Vite 读取: npm run build  (vite build --mode production)
# 运行时会按 import.meta.env.VITE_* 注入到前端代码
# =============================================================================

# API 基础路径（生产环境通过 Nginx 反向代理，设为相对路径即可）
VITE_API_BASE_URL=/api

# 应用标题
VITE_APP_TITLE=星火智慧养老 - 管理后台
