<view class="container">
  <!-- 顶部个人信息卡片 -->
  <view class="header-card">
    <view class="header-bg"></view>
    <view class="header-content">
      <image class="user-avatar" src="{{userInfo.avatar || '/images/logo.png'}}" mode="aspectFill" />
      <text class="user-nickname">{{userInfo.nickname || '志愿者'}}</text>
      <view class="level-badge">
        <text>Lv.{{userInfo.level || 1}}</text>
      </view>
      <text class="user-role">爱心志愿者</text>
      <text class="user-region" wx:if="{{userInfo.region}}">{{userInfo.region}}</text>
    </view>
  </view>

  <!-- 数据统计行 -->
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{stats.points || 0}}</text>
      <text class="stat-label">积分</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.completedTasks || 0}}</text>
      <text class="stat-label">完成任务</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.checkinDays || 0}}</text>
      <text class="stat-label">连续签到</text>
    </view>
  </view>

  <!-- 成就勋章墙 -->
  <view class="section-card">
    <text class="section-title">成就勋章</text>
    <view class="badge-wall">
      <view class="badge-item {{item.unlocked ? 'unlocked' : 'locked'}}" wx:for="{{badges}}" wx:key="id">
        <text class="badge-icon">{{item.unlocked ? item.icon : '🔒'}}</text>
        <text class="badge-name">{{item.name}}</text>
      </view>
    </view>
  </view>

</view>
