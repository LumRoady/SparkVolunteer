/* ========== 页面容器 ========== */
.container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding-bottom: 64rpx;
}

/* ========== 头部个人信息卡片 ========== */
.header-card {
  position: relative;
  margin-bottom: 24rpx;
}

.header-bg {
  height: 240rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #e55a5a 100%);
  border-radius: 0 0 32rpx 32rpx;
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -80rpx;
  padding-bottom: 32rpx;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
  background: #eee;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.user-nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #2d3436;
  margin-top: 16rpx;
}

.level-badge {
  margin-top: 8rpx;
  padding: 6rpx 24rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8787 100%);
  border-radius: 20rpx;
}

.level-badge text {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
}

.user-role {
  font-size: 26rpx;
  color: #b2bec3;
  margin-top: 8rpx;
}

.user-region {
  font-size: 24rpx;
  color: #636e72;
  margin-top: 6rpx;
}

/* ========== 数据统计行 ========== */
.stats-row {
  display: flex;
  background: #ffffff;
  border-radius: 12rpx;
  margin: 0 24rpx 24rpx;
  padding: 32rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #ff6b6b;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #b2bec3;
  margin-top: 8rpx;
  display: block;
}

.stat-divider {
  width: 2rpx;
  background: #f5f6fa;
}

/* ========== 通用卡片 ========== */
.section-card {
  background: #ffffff;
  border-radius: 12rpx;
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d3436;
  display: block;
  margin-bottom: 24rpx;
}

/* ========== 勋章墙 ========== */
.badge-wall {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.badge-item {
  width: calc(33.33% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 8rpx;
  border-radius: 12rpx;
  background: #f5f6fa;
}

.badge-item.unlocked {
  background: linear-gradient(135deg, #fff9e6 0%, #fff3cd 100%);
}

.badge-item.locked {
  opacity: 0.5;
}

.badge-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.badge-name {
  font-size: 22rpx;
  color: #636e72;
  font-weight: 500;
  text-align: center;
}

