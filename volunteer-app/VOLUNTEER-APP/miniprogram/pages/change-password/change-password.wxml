<view class="change-password-container">
  <view class="change-password-content">
    <view class="form-item">
      <text class="form-label">原密码</text>
      <input class="form-input" placeholder="请输入原密码" password bindinput="onOldPasswordChange" />
    </view>
    <view class="form-item">
      <text class="form-label">新密码</text>
      <input class="form-input" placeholder="请输入新密码" password bindinput="onNewPasswordChange" />
      <view class="password-strength" wx:if="newPassword">
        <text class="strength-label">密码强度：</text>
        <view class="strength-bars">
          <view class="strength-bar {{newPassword.length > 0 ? 'weak' : ''}} {{newPassword.length >= 8 && hasNumber && hasLetter ? 'strong' : ''}}"></view>
          <view class="strength-bar {{newPassword.length >= 6 ? 'medium' : ''}} {{newPassword.length >= 8 && hasNumber && hasLetter ? 'strong' : ''}}"></view>
          <view class="strength-bar {{newPassword.length >= 8 && hasNumber && hasLetter ? 'strong' : ''}}"></view>
        </view>
      </view>
    </view>
    <view class="form-item">
      <text class="form-label">确认新密码</text>
      <input class="form-input" placeholder="请确认新密码" password bindinput="onConfirmPasswordChange" />
    </view>
    
    <button class="confirm-btn" bindtap="confirmChangePassword">
      <text>确认修改</text>
    </button>
  </view>
</view>