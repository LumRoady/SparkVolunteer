.change-password-container {
  padding: 20rpx 5rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.change-password-content {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: bold;
}



.password-strength {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.strength-label {
  font-size: 22rpx;
  color: #666;
}

.strength-bars {
  display: flex;
  gap: 8rpx;
  flex: 1;
}

.strength-bar {
  flex: 1;
  height: 8rpx;
  background-color: #e0e0e0;
  border-radius: 4rpx;
  transition: all 0.3s ease;
}

.strength-bar.weak {
  background-color: #ff6b6b;
}

.strength-bar.medium {
  background-color: #ffd93d;
}

.strength-bar.strong {
  background-color: #4caf50;
}

.form-input {
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 25rpx 20rpx;
  font-size: 24rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
}

.confirm-btn {
  width: 100%;
  padding: 20rpx;
  background-color: #ff6b6b;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  margin-top: 20rpx;
}

.confirm-btn:active {
  background-color: #ff5252;
}