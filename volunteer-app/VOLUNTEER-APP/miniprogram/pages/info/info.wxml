<view class="container">
  <!-- 分类选项卡 — 同首页排行榜风格 -->
  <view class="rank-tabs">
    <view class="rank-tab {{activeTab==='all'?'active':''}}" bindtap="switchTab" data-tab="all"><text>全部</text></view>
    <view class="rank-tab {{activeTab==='task'?'active':''}}" bindtap="switchTab" data-tab="task"><text>任务</text></view>
    <view class="rank-tab {{activeTab==='system'?'active':''}}" bindtap="switchTab" data-tab="system"><text>系统</text></view>
    <view class="rank-tab {{activeTab==='activity'?'active':''}}" bindtap="switchTab" data-tab="activity"><text>活动</text></view>
  </view>

  <!-- 通知列表 -->
  <view class="notify-list">
    <view class="empty-state" wx:if="{{filteredList.length === 0}}">
      <text class="empty-text">暂无通知</text>
    </view>

    <view
      class="notify-card {{item.read ? '' : 'unread'}} {{batchMode ? 'batch-mode' : ''}} {{selectedIds.indexOf(item.id) > -1 ? 'selected' : ''}}"
      wx:for="{{filteredList}}"
      wx:key="id"
      bindtap="handleTapCard"
      data-id="{{item.id}}"
    >
      <!-- 批量模式复选框 -->
      <view class="batch-checkbox" wx:if="{{batchMode}}">
        <view class="checkbox {{selectedIds.indexOf(item.id) > -1 ? 'checked' : ''}}"></view>
      </view>

      <!-- 未读红点 -->
      <view class="unread-dot" wx:if="{{!item.read && !batchMode}}"></view>

      <!-- 左侧图标 -->
      <view class="card-icon-wrap">
        <text class="card-icon">{{item.icon}}</text>
      </view>

      <!-- 右侧内容 -->
      <view class="card-body">
        <view class="card-title-row">
          <text class="card-title">{{item.title}}</text>
          <view class="card-red-dot" wx:if="{{!item.read && !batchMode}}"></view>
        </view>
        <text class="card-content">{{item.content}}</text>
        <text class="card-time">{{item.timeText}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{!batchMode}}">
    <view class="bottom-btn primary" bindtap="handleMarkAllRead"><text>全部已读</text></view>
    <view class="bottom-btn secondary" bindtap="handleBatchAction"><text>批量操作</text></view>
  </view>

  <!-- 批量操作栏 -->
  <view class="batch-bar" wx:if="{{batchMode}}">
    <view class="batch-left" bindtap="toggleSelectAll">
      <view class="checkbox {{isAllSelected ? 'checked' : ''}}"></view>
      <text>全选</text>
    </view>
    <view class="batch-right">
      <view class="batch-btn cancel" bindtap="exitBatchMode"><text>取消</text></view>
      <view class="batch-btn mark-read" bindtap="handleBatchMarkRead"><text>标记已读</text></view>
      <view class="batch-btn delete" bindtap="handleBatchDelete"><text>删除{{selectedIds.length > 0 ? '(' + selectedIds.length + ')' : ''}}</text></view>
    </view>
  </view>
</view>
