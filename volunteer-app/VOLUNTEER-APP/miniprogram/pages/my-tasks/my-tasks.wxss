.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8787 100%);
  padding: 32rpx;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

/* 全局字体样式 */
text, button {
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-weight: 400;
}

.header {
  padding: 30rpx 0;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2c3e50;
}

.task-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.task-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 32rpx;
  color: #666666;
  position: relative;
  transition: all 0.3s ease;
}

.task-tab.active {
  color: #ff6b6b;
  font-weight: 600;
}

.task-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 6rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8787 100%);
  border-radius: 3rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.task-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
  flex: 1;
}

.task-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  margin-left: 20rpx;
}

.task-status.pending {
  background: #fff3cd;
  color: #856404;
}

.task-status.in_progress {
  background: #cce7ff;
  color: #004085;
}

.task-status.completed {
  background: #d4edda;
  color: #155724;
}

.task-desc {
  font-size: 28rpx;
  color: #7f8c8d;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.task-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 25rpx;
  font-size: 24rpx;
  color: #95a5a6;
}

.task-actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-top: 20rpx;
}

.action-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8787 100%);
  color: white;
  border: none;
  border-radius: 44rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  width: 100%;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
}

.action-btn.secondary {
  background: rgba(255, 255, 255, 0.8);
  color: #ff6b6b;
  border: 2rpx solid #ff6b6b;
  box-shadow: none;
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.2);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
}
