/* 日常咨询页面样式 */
.consultation-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.corner {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.top-left {
  top: -80rpx;
  left: -80rpx;
}

.top-right {
  top: -80rpx;
  right: -80rpx;
}

.bottom-left {
  bottom: -80rpx;
  left: -80rpx;
}

.bottom-right {
  bottom: -80rpx;
  right: -80rpx;
}

/* 顶部信息 */
.top-info {
  position: absolute;
  top: 40rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 0 32rpx;
  z-index: 10;
}

.distance-info, .weather-info {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 中间核心区域 */
.core-area {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  z-index: 20;
}

/* 咨询图标 */
.consult-icon-container {
  margin-bottom: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.consult-icon {
  width: 220rpx;
  height: 220rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 60rpx rgba(255, 255, 255, 0.7);
  transition: all 0.3s ease;
}

/* 发光动画 - 柔和效果 */
.glow-animation {
  animation: gentle-glow 3s infinite ease-in-out;
}

@keyframes gentle-glow {
  0%, 100% {
    box-shadow: 0 0 60rpx rgba(255, 255, 255, 0.7);
  }
  50% {
    box-shadow: 0 0 80rpx rgba(255, 255, 255, 0.85);
  }
}

.consult-icon-emoji {
  font-size: 80rpx;
}

/* 日常咨询标题 - 绿色背景box */
.consult-title-box {
  display: inline-block;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.95) 0%, rgba(5, 150, 105, 0.95) 100%);
  padding: 24rpx 64rpx;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

/* 咨询标题 */
.consult-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* 底部悬浮操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  gap: 20rpx;
  z-index: 30;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 20rpx;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.25);
}

/* 导航前往按钮 - 绿色背景 */
.nav-btn {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.95) 0%, rgba(5, 150, 105, 0.95) 100%);
  border-color: rgba(16, 185, 129, 0.9);
  box-shadow: 0 8rpx 28rpx rgba(16, 185, 129, 0.4);
}

.nav-btn:active {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.85) 0%, rgba(5, 150, 105, 0.85) 100%);
}

/* 我已到达按钮 */
.arrive-btn {
  background: rgba(255, 255, 255, 0.2);
}

.arrive-btn.completed-btn {
  background: rgba(72, 187, 120, 0.3);
  border-color: rgba(72, 187, 120, 0.6);
}

/* 联系老人按钮 */
.contact-btn {
  background: rgba(255, 255, 255, 0.2);
  border-color: rgba(255, 255, 255, 0.8);
}

.btn-text {
  font-size: 30rpx;
  font-weight: bold;
  color: white;
}

