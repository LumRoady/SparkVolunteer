.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4edf5 100%);
  display: flex;
  flex-direction: column;
}



.notification-detail {
  background: white;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.05);
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.notification-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.icon {
  font-size: 50rpx;
  color: white;
}

.notification-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 20rpx;
  text-align: center;
}

.notification-time {
  font-size: 24rpx;
  color: #95a5a6;
  margin-bottom: 30rpx;
}

.notification-content {
  font-size: 28rpx;
  color: #7f8c8d;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 40rpx;
  flex: 1;
}

.notification-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  margin-top: 20rpx;
}

.action-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.action-btn.secondary {
  background: white;
  color: #ff6b6b;
  border: 2rpx solid #ff6b6b;
}

.action-btn::after {
  border: none;
}
