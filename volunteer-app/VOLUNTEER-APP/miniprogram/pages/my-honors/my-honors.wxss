.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 40rpx 28rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  text-align: center;
  margin-bottom: 32rpx;
}
.title {
  font-size: 36rpx;
  font-weight: 800;
  color: #2d3436;
  display: block;
  margin-bottom: 10rpx;
}
.subtitle {
  font-size: 26rpx;
  color: #b2bec3;
}

.avatar-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}
.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.35s;
}
.avatar-wrap.zoomed {
  transform: scale(1.18);
  box-shadow: 0 0 0 12rpx rgba(250,116,114,0.2);
}
.avatar-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: #eee;
}
.avatar-tip {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #b2bec3;
}

.badge-grid {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.badge-card {
  width: calc((100% - 40rpx) / 3);
  aspect-ratio: 0.85;
  background: #fff0f0;
  border: 2rpx solid #fa7472;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx;
  box-sizing: border-box;
}
.badge-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}
.badge-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #2d3436;
  text-align: center;
}
.badge-desc {
  font-size: 18rpx;
  color: #b2bec3;
  margin-top: 4rpx;
}
