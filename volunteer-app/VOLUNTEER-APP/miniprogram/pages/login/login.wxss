/* ========== 页面容器 ========== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #ff6b6b 0%, #f5f6fa 50%);
  padding: 0 48rpx;
}

/* ========== Logo区域 ========== */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  padding-bottom: 80rpx;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.15);
  padding: 12rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.logo-img {
  width: 100%;
  height: 100%;
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
  display: block;
}

/* ========== 登录表单 ========== */
.form-section {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 32rpx;
  color: #2d3436;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 24rpx;
  border: 2rpx solid #dfe6e9;
  border-radius: 12rpx;
  font-size: 32rpx;
  color: #2d3436;
  box-sizing: border-box;
  background: #fafafa;
}

.form-input:focus {
  border-color: #ff6b6b;
  background: #ffffff;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 100%);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(255,107,107,0.3);
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  background: #b2bec3;
  box-shadow: none;
}

.form-extra {
  display: flex;
  justify-content: space-between;
  margin-top: 28rpx;
  padding: 0 8rpx;
}

.extra-link {
  font-size: 28rpx;
  color: #ff6b6b;
}

/* ========== 协议 ========== */
.agreement-text {
  text-align: center;
  padding: 48rpx 0;
}

.agreement-text text {
  font-size: 24rpx;
  color: #b2bec3;
}

.agreement-text .link {
  color: #ff6b6b;
}
