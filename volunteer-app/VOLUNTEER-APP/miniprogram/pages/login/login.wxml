<view class="container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo-wrap">
      <image class="logo-img" src="../../images/logo_main.png" mode="aspectFit" />
    </view>
    <text class="app-name">星火众擎</text>
    <text class="app-slogan">智慧养老 · 志愿同行</text>
  </view>

  <!-- 登录表单 -->
  <view class="form-section">
    <view class="form-group">
      <text class="form-label">手机号</text>
      <input class="form-input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
    </view>

    <view class="form-group">
      <text class="form-label">密码</text>
      <input class="form-input" type="password" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
    </view>

    <button class="login-btn" bindtap="handleLogin" disabled="{{submitting || !canSubmit}}">
      <text>{{submitting ? '登录中...' : '登录'}}</text>
    </button>

    <view class="form-extra">
      <text class="extra-link" bindtap="goToRegister">注册账号</text>
      <text class="extra-link" bindtap="goToForgotPassword">忘记密码</text>
    </view>
  </view>

  <!-- 协议 -->
  <view class="agreement-text">
    <text>登录即表示同意</text>
    <text class="link" bindtap="goToUserAgreement">《用户协议》</text>
    <text>和</text>
    <text class="link" bindtap="goToPrivacyPolicy">《隐私政策》</text>
  </view>
</view>
