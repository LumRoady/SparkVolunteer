<view class="publish-container">
  <view class="form-section">

    <view class="form-group">
      <text class="form-label">任务标题</text>
      <input 
        class="uni-input" 
        placeholder="请输入任务标题，如：陪老人聊天、协助买菜等（也可通过遥控器一键发布）"
        value="{{formData.title}}"
        bindinput="handleInput"
        data-field="title"
      />
    </view>
    
    <view class="form-group">
      <text class="form-label">任务描述</text>
      <textarea 
        class="uni-textarea" 
        placeholder="请详细描述任务内容，特别是老人的具体需求...（紧急情况可按遥控器红色按钮一键求助）"
        value="{{formData.description}}"
        bindinput="handleInput"
        data-field="description"
        maxlength="500"
      />
    </view>
    
    <view class="form-group">
      <text class="form-label">地点</text>
      <input 
        class="uni-input" 
        placeholder="请输入地点"
        value="{{formData.location}}"
        bindinput="handleInput"
        data-field="location"
      />
    </view>
    
    <view class="form-group">
      <text class="form-label">联系方式</text>
      <input 
        class="uni-input" 
        placeholder="请输入联系电话"
        value="{{formData.contact}}"
        bindinput="handleInput"
        data-field="contact"
      />
    </view>
    
    <view class="form-group">
      <text class="form-label">任务类型</text>
      <radio-group bindchange="handleTaskTypeChange">
        <label class="radio-label"><radio value="normal" checked/> 普通任务</label>
        <label class="radio-label"><radio value="challenge"/> 任务挑战</label>
      </radio-group>
    </view>
    
    <view class="form-group" wx:if="{{formData.taskType === 'challenge'}}">
      <text class="form-label">奖励积分</text>
      <input 
        class="uni-input" 
        placeholder="请输入奖励积分"
        value="{{formData.reward}}"
        bindinput="handleInput"
        data-field="reward"
        type="number"
      />
    </view>
    
    <button 
      class="submit-btn" 
      disabled="{{!canSubmit}}"
      bindtap="publishTask"
    >
      <text>{{submitting ? '发布中...' : (formData.taskType === 'challenge' ? '发布挑战' : '发布任务')}}</text>
    </button>
  </view>
</view>