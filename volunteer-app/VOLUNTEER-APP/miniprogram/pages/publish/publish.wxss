.publish-container {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 32rpx;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

/* 全局字体样式 */
text, input, textarea, button {
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-weight: 400;
}

.header {
  padding: 30rpx 0;
  text-align: center;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #7f8c8d;
}

.form-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx;
  margin-top: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid #E5E5E5;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #2c3e50;
  margin-bottom: 15rpx;
  font-weight: bold;
}

.radio-group {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.radio-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 15rpx;
  padding: 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  justify-content: center;
}

.radio-item.active {
  border-color: #3498db;
  background: #e3f2fd;
}

.radio-circle {
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid #ccc;
  border-radius: 50%;
}

.radio-circle.active {
  border-color: #3498db;
  position: relative;
}

.radio-circle.active::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 10rpx;
  height: 10rpx;
  background-color: #3498db;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.uni-input {
  width: 100%;
  height: 88rpx;
  padding: 0 32rpx;
  border: 2rpx solid rgba(255, 107, 107, 0.3);
  border-radius: 16rpx;
  font-size: 32rpx;
  background: rgba(255, 255, 255, 0.8);
  box-sizing: border-box;
  color: #333333;
  transition: all 0.3s ease;
}

.uni-input:focus {
  border-color: #ff6b6b;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.1);
}

.uni-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 32rpx;
  border: 2rpx solid rgba(255, 107, 107, 0.3);
  border-radius: 16rpx;
  font-size: 32rpx;
  background: rgba(255, 255, 255, 0.8);
  box-sizing: border-box;
  color: #333333;
  transition: all 0.3s ease;
}

.uni-textarea:focus {
  border-color: #ff6b6b;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.1);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8787 100%);
  color: white;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-sizing: border-box;
  padding: 0;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
}

.submit-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.2);
}

.submit-btn[disabled] {
  background: linear-gradient(135deg, #9E9E9E 0%, #BDBDBD 100%);
  box-shadow: none;
}

.submit-btn::after {
  border: none;
}

.radio-label {
  display: inline-block;
  margin-right: 48rpx;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  color: #333333;
}
