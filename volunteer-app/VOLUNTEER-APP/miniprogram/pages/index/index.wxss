/* 页面容器 */
.container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding-bottom: 32rpx;
}

/* ========== 视角切换条 ========== */
.view-switch-bar {
  padding: 20rpx 20rpx 0;
}

.switch-track {
  position: relative;
  display: flex;
  background: #e8eaed;
  border-radius: 40rpx;
  padding: 6rpx;
  overflow: hidden;
}

.switch-slider {
  position: absolute;
  top: 6rpx;
  width: 50%;
  height: calc(100% - 12rpx);
  background: #ffffff;
  border-radius: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  transition: left 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 0;
}

.switch-option {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  font-weight: 600;
  color: #636e72;
  border-radius: 36rpx;
  position: relative;
  z-index: 1;
  transition: color 0.2s;
}

.switch-option.active {
  color: #ff6b6b;
}

/* ========== 轮播图 ========== */
.banner-section {
  padding: 32rpx 20rpx 8rpx;
}

.banner-swiper {
  height: 320rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 100%;
}

/* ========== 快捷入口 ========== */
.action-section {
  display: flex;
  padding: 32rpx 20rpx;
  gap: 20rpx;
}

.action-box {
  flex: 1;
  padding: 36rpx 0;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.box-solid {
  background: linear-gradient(160deg, #ff6b6b 0%, #e55a5a 100%);
  box-shadow: 0 12rpx 32rpx rgba(255,107,107,0.35);
}

.box-outline {
  background: #ffffff;
  border: 3rpx solid #ff6b6b;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06);
}

.box-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #ffffff;
}

.outline-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #ff6b6b;
}

/* ========== 排行榜 ========== */
.rank-section {
  padding: 0 20rpx;
  margin-top: 32rpx;
}

.rank-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 10rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.rank-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #636e72;
  transition: all 0.2s;
}

.rank-tab.active {
  background: linear-gradient(135deg, #ff6b6b, #e55a5a);
  color: #fff;
  font-weight: 600;
}

.rank-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-empty {
  background: #fff;
  border-radius: 12rpx;
  padding: 80rpx;
  text-align: center;
}

.rank-empty text {
  font-size: 28rpx;
  color: #b2bec3;
}

.rank-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.rank-num {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #b2bec3;
  flex-shrink: 0;
}

.rank-num.top1,
.rank-num.top2,
.rank-num.top3 {
  font-size: 40rpx;
}

.rank-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #eee;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.rank-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.rank-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d3436;
  display: block;
}

.rank-community {
  font-size: 24rpx;
  color: #b2bec3;
  margin-top: 4rpx;
  display: block;
}

.rank-score {
  text-align: right;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.score-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff6b6b;
  display: block;
}

.score-label {
  font-size: 22rpx;
  color: #b2bec3;
}

/* ========== 展开更多 ========== */
.rank-expand {
  text-align: center;
  padding: 24rpx 0 8rpx;
}

.rank-expand text {
  font-size: 26rpx;
  color: #b2bec3;
}

/* ========== 需求者-一键发布 ========== */
.quick-section {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 20rpx;
}
.quick-card {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  box-shadow: 0 12rpx 40rpx rgba(255,107,107,0.25), 0 4rpx 12rpx rgba(0,0,0,0.1);
  transition: transform 0.2s, box-shadow 0.2s;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.quick-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}
.quick-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}
.quick-card:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}
.quick-card.sos { background: linear-gradient(135deg, #ff3b30, #cc0000); }
.quick-card.life { background: linear-gradient(135deg, #ffa502, #ffbe76); }
.quick-card.consult { background: linear-gradient(135deg, #2ed573, #7bed9f); }

/* ========== 需求者-我的求助 ========== */
.mytask-section {
  padding: 0 20rpx;
  margin-top: 8rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d3436;
  margin-bottom: 16rpx;
  display: block;
}
.mytask-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.mytask-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.mt-type {
  width: 64rpx;
  padding: 8rpx 0;
  text-align: center;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}
.mt-body { flex: 1; }
.mt-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3436;
  display: block;
}
.mt-time { font-size: 22rpx; color: #b2bec3; margin-top: 4rpx; display: block; }
.mt-status { font-size: 24rpx; font-weight: 600; color: #ff6b6b; }
.mytask-empty {
  text-align: center;
  padding: 60rpx 0;
  font-size: 26rpx;
  color: #b2bec3;
}

/* ========== 底部文案 ========== */
.footer-text {
  text-align: center;
  padding: 48rpx 0 32rpx;
}

.footer-text text {
  font-size: 24rpx;
  color: #cccccc;
}
