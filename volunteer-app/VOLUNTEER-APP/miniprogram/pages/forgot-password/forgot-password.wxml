<view class="forgot-password-container">
  <view class="forgot-password-wrapper">
    <!-- 忘记密码表单 -->
    <view class="forgot-password-form-section">
      <view class="forgot-password-header">
        <view class="logo">
          <text class="logo-text">欢迎使用星火众擎</text>
        </view>
      </view>
      
      <view class="forgot-password-form">
        <view class="input-group">
          <view class="input-item">
            <input 
              value="{{forgotForm.phone}}" 
              bindinput="handleInput" 
              data-field="phone"
              class="uni-input" 
              placeholder="请输入手机号" 
              type="number"
            />
          </view>
          
          <view class="input-item">
            <input 
              value="{{forgotForm.verificationCode}}" 
              bindinput="handleInput" 
              data-field="verificationCode"
              class="uni-input verification-input" 
              placeholder="请输入验证码" 
              type="number"
            />
            <button class="verification-btn" bindtap="sendVerificationCode" disabled="{{countdown > 0}}">
              <text>{{countdown > 0 ? countdown + '秒后重发' : '发送验证码'}}</text>
            </button>
          </view>
          
          <view class="input-item">
            <input 
              value="{{forgotForm.newPassword}}" 
              bindinput="handleInput" 
              data-field="newPassword"
              class="uni-input" 
              placeholder="请输入新密码" 
              password
            />
          </view>
          
          <view class="input-item">
            <input 
              value="{{forgotForm.confirmPassword}}" 
              bindinput="handleInput" 
              data-field="confirmPassword"
              class="uni-input" 
              placeholder="请确认新密码" 
              password
            />
          </view>
        </view>
        
        <button 
          class="reset-btn" 
          loading="{{loading}}"
          bindtap="resetPassword"
        >
          <text wx:if="!loading">重置密码</text>
          <text wx:else>重置中...</text>
        </button>
        
        <view class="back-to-login">
          <text class="back-text">想起密码了？</text>
          <text class="login-link" bindtap="goToLogin">立即登录</text>
        </view>
      </view>
    </view>
  </view>
</view>