page {
  background-color: #f8f9fa;
  min-height: 100vh;
}

.forgot-password-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #f9f7f7 0%, #e8f5e8 50%, #f3e5f5 100%);
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
}

.forgot-password-wrapper {
  width: 100%;
  max-width: 1000rpx;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.forgot-password-form-section {
  padding: 60rpx 40rpx;
}

.forgot-password-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.logo {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.logo-icon {
  font-size: 40rpx;
  color: #ff6b6b;
}

.logo-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #2c3e50;
}

.title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  color: #2c3e50;
}

.subtitle {
  display: block;
  color: #7f8c8d;
  margin-bottom: 30rpx;
  font-size: 24rpx;
}

.input-group {
  margin-bottom: 20rpx;
}

.input-item {
  margin-bottom: 20rpx;
  position: relative;
}

.uni-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1px solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 14px;
  background-color: #f8f9fa;
  box-sizing: border-box;
}

.verification-input {
  padding-right: 200rpx;
  box-sizing: border-box;
}

.verification-btn {
  position: absolute;
  right: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  height: 60rpx;
  padding: 0 20rpx;
  border: 1px solid #ff6b6b;
  background: white;
  border-radius: 30rpx;
  color: #ff6b6b;
  font-size: 24rpx;
  box-sizing: border-box;
}

.verification-btn::after {
  border: none;
}

.reset-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  border: none;
  border-radius: 10rpx;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.reset-btn::after {
  border: none;
}

.back-to-login {
  text-align: center;
  margin-top: 20rpx;
}

.back-text {
  color: #7f8c8d;
  font-size: 24rpx;
}

.login-link {
  color: #3498db;
  font-size: 24rpx;
  margin-left: 5rpx;
}
