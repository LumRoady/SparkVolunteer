page {
  background-color: #F5F5F5;
  min-height: 100vh;
}

.register-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.register-wrapper {
  width: 100%;
  max-width: 1000rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.register-form-section {
  padding: 64rpx 48rpx;
}

.register-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.logo {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.logo-icon {
  font-size: 40rpx;
  color: #ff6b6b;
}

.logo-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.slogan {
  color: #999999;
  font-size: 24rpx;
}

.register-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #333333;
  text-align: center;
}

.form-subtitle {
  display: block;
  color: #666666;
  margin-bottom: 48rpx;
  text-align: center;
  font-size: 24rpx;
}

.input-group {
  margin-bottom: 48rpx;
  width: 100%;
}

.input-item {
  margin-bottom: 48rpx;
  width: 100%;
}

.uni-input {
  width: 100%;
  height: 88rpx;
  padding: 0 32rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 16rpx;
  font-size: 32rpx;
  background-color: #FFFFFF;
  box-sizing: border-box;
  color: #333333;
}

.radio-group {
  margin-bottom: 48rpx;
  width: 100%;
  box-sizing: border-box;
}

.radio-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 24rpx;
}

.radio-options {
  display: flex;
  justify-content: space-between;
  gap: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.radio-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 16rpx;
  background-color: #FFFFFF;
  box-sizing: border-box;
}

.radio-option.active {
  border-color: #ff6b6b;
  background-color: rgba(255, 107, 107, 0.1);
}

.radio-circle {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid #CCCCCC;
  border-radius: 50%;
}

.radio-circle.active {
  border-color: #ff6b6b;
  position: relative;
}

.radio-circle.active::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 12rpx;
  height: 12rpx;
  background-color: #ff6b6b;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.register-btn {
  width: 100%;
  height: 88rpx;
  background: #ff6b6b;
  border: none;
  border-radius: 44rpx;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 48rpx;
  box-sizing: border-box;
}

.register-btn::after {
  border: none;
}

.divider {
  display: flex;
  align-items: center;
  margin: 48rpx 0;
  color: #999999;
  width: 100%;
  box-sizing: border-box;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 2rpx;
  background: #E5E5E5;
}

.divider-text {
  padding: 0 32rpx;
  font-size: 28rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #E5E5E5;
  background: #FFFFFF;
  border-radius: 44rpx;
  color: #333333;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 48rpx;
  box-sizing: border-box;
}

.login-btn::after {
  border: none;
}

.register-footer {
  margin-top: 64rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}

.footer-text {
  font-size: 24rpx;
}

.link {
  color: #ff6b6b;
}