<view class="settings-container {{fontSizeClass}}">

  <view class="settings-content">
    <view class="setting-section">
      <text class="section-title">账户设置</text>
      <view class="setting-item" bindtap="goToProfile">
        <text class="setting-label">个人信息</text>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="goToChangePassword">
        <text class="setting-label">修改密码</text>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="goToBindPhone">
        <text class="setting-label">绑定手机</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
    
    <view class="setting-section">
      <text class="section-title">通知设置</text>
      <view class="setting-item">
        <text class="setting-label">接收任务通知</text>
        <switch checked bindchange="toggleNotifications" />
      </view>
      <view class="setting-item">
        <text class="setting-label">接收求助提醒</text>
        <switch checked bindchange="toggleHelpAlerts" />
      </view>
    </view>
    
    <view class="setting-section">
      <text class="section-title">通用设置</text>
      <view class="setting-item" bindtap="goToLanguage">
        <text class="setting-label">语言</text>
        <text class="setting-value">简体中文</text>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item">
        <text class="setting-label">字体大小</text>
        <picker bindchange="changeFontSize" value="{{fontSizeIndex}}" range="{{fontSizes}}">
          <text class="setting-value">{{fontSizes[fontSizeIndex]}}</text>
          <text class="setting-arrow">›</text>
        </picker>
      </view>
      <view class="setting-item" bindtap="clearCache">
        <text class="setting-label">清除缓存</text>
        <text class="setting-value">12.3MB</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
    
    <view class="setting-section">
      <text class="section-title">关于</text>
      <view class="setting-item">
        <text class="setting-label">版本信息</text>
        <text class="setting-value">v1.0.0</text>
      </view>
      <view class="setting-item" bindtap="goToAboutUs">
        <text class="setting-label">关于我们</text>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="goToUserAgreement">
        <text class="setting-label">用户协议</text>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="goToPrivacyPolicy">
        <text class="setting-label">隐私政策</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
    
    <button class="logout-btn" bindtap="logout">
      <text>退出登录</text>
    </button>
  </view>
</view>