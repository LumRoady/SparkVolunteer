.settings-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  padding: 30rpx 20rpx;
  background-color: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.settings-content {
  padding: 20rpx 0;
}

.setting-section {
  background-color: white;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 0.85em;
  color: #ff6b6b;
  padding: 0 20rpx 10rpx;
  font-weight: bold;
  margin-top: 20rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.setting-label {
  font-size: 1em;
  color: #333;
}

.setting-arrow {
  font-size: 1.14em;
  color: #ff6b6b;
}

.setting-value {
  font-size: 0.93em;
  color: #7f8c8d;
  margin-right: 10rpx;
}

.logout-btn {
  width: 90%;
  margin: 40rpx auto;
  background-color: #ff6b6b;
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 25rpx;
  font-size: 1em;
  font-weight: bold;
}

.logout-btn::after {
  border: none;
}
