.contact-container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.contact-content {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.contact-info {
  margin-bottom: 40rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 60rpx;
  text-align: center;
}

.contact-details {
  flex: 1;
}

.contact-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 5rpx;
  display: block;
}

.contact-value {
  font-size: 26rpx;
  color: #333;
  display: block;
}

.feedback-section {
  margin-top: 40rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.feedback-input {
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 24rpx;
  color: #333;
  min-height: 200rpx;
  resize: none;
  margin-bottom: 20rpx;
}

.submit-btn {
  width: 100%;
  padding: 20rpx;
  background-color: #ff6b6b;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.submit-btn:active {
  background-color: #ff5252;
}