.page-container {
  padding: 20rpx;
  padding-bottom: 140rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.change-btn {
  padding: 12rpx 24rpx;
  border: 2rpx solid #ff6b6b;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #ff6b6b;
}

.header-info {
  text-align: right;
}

.progress-text {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.points-text {
  font-size: 24rpx;
  color: #ff6b6b;
}

.challenge-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 20rpx;
}

.challenge-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.challenge-item:last-child {
  border-bottom: none;
}

.challenge-left {
  flex: 1;
  margin-right: 20rpx;
}

.challenge-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.challenge-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.challenge-reward {
  font-size: 24rpx;
  color: #ff6b6b;
}

.challenge-right {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.btn-outline {
  padding: 12rpx 24rpx;
  border: 2rpx solid #ff6b6b;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #ff6b6b;
  text-align: center;
  white-space: nowrap;
}

.btn-solid {
  padding: 12rpx 24rpx;
  background: #ff6b6b;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #fff;
  text-align: center;
  white-space: nowrap;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.type-input {
  width: 100%;
  padding: 36rpx 28rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.desc-input {
  width: 100%;
  height: 180rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  background: #ff6b6b;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #fff;
  text-align: center;
  margin-bottom: 28rpx;
  box-sizing: border-box;
}

.history-section {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 24rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 16rpx;
}

.history-tag {
  padding: 6rpx 16rpx;
  background: #ff6b6b;
  color: #fff;
  font-size: 22rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  height: 40rpx;
  line-height: 28rpx;
}

.history-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.history-desc {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.history-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-date {
  font-size: 22rpx;
  color: #999;
}

.history-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.status-done {
  background: #ff6b6b;
  color: #fff;
}

.status-processing {
  background: #ff9966;
  color: #fff;
}