/* ====== 深红全屏背景 ====== */
.emergency-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #8B0000 0%, #4a0000 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* ====== 四角装饰圈 ====== */
.corner {
  position: absolute;
  width: 160rpx; height: 160rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 50%;
}
.top-left     { top: -80rpx; left: -80rpx; }
.top-right    { top: -80rpx; right: -80rpx; }
.bottom-left  { bottom: 200rpx; left: -80rpx; }
.bottom-right { bottom: 200rpx; right: -80rpx; }

/* ====== 顶部距离/天气 ====== */
.top-info {
  position: absolute; top: 50rpx; left: 32rpx; right: 32rpx;
  display: flex; justify-content: space-between; z-index: 10;
}
.distance-info, .weather-info {
  font-size: 24rpx; color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.1); padding: 8rpx 18rpx; border-radius: 20rpx;
}

/* ====== 核心区 ====== */
.core-area {
  display: flex; flex-direction: column; align-items: center;
}

/* SOS 红色圆 + 波纹 */
.sos-icon-container {
  position: relative; width: 300rpx; height: 300rpx;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 50rpx;
}
.sos-icon {
  width: 220rpx; height: 220rpx; border-radius: 50%;
  background: radial-gradient(circle at 40% 40%, #ff4444, #aa0000);
  display: flex; align-items: center; justify-content: center;
  z-index: 10;
  box-shadow: 0 0 80rpx rgba(255,0,0,0.7), 0 0 160rpx rgba(255,0,0,0.3);
}
.sos-text {
  font-size: 68rpx; font-weight: 900; color: #fff; letter-spacing: 8rpx;
}

/* 地震预警式波纹 */
.ripple {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
  width: 220rpx; height: 220rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,80,80,0.6);
  animation: ripple 2.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) infinite;
}
.ripple-1 { animation-delay: 0s; }
.ripple-2 { animation-delay: 0.8s; }
.ripple-3 { animation-delay: 1.6s; }
@keyframes ripple {
  0%   { width: 220rpx; height: 220rpx; opacity: 1; border-width: 4rpx; }
  100% { width: 560rpx; height: 560rpx; opacity: 0; border-width: 1rpx; }
}

/* SOS 呼吸脉冲 */
.pulse-animation { animation: pulse 1.2s ease-in-out infinite; }
@keyframes pulse {
  0%,100% { transform: scale(1); }
  50%    { transform: scale(1.06); }
}

/* ====== 紧急求助中珊瑚红Box ====== */
.emergency-title-box {
  background: #ff6b6b;
  border-radius: 20rpx; padding: 26rpx 64rpx; margin-bottom: 28rpx;
  box-shadow: 0 10rpx 36rpx rgba(255,107,107,0.5);
}
.emergency-title {
  font-size: 42rpx; font-weight: 800; color: #fff; letter-spacing: 8rpx;
}

/* ====== 已等待计时珊瑚红Box ====== */
.countdown-box {
  background: #ff6b6b;
  border-radius: 20rpx; padding: 28rpx 56rpx; margin-bottom: 20rpx;
  display: flex; align-items: center; gap: 18rpx;
  box-shadow: 0 10rpx 36rpx rgba(255,107,107,0.5);
}
.countdown-label { font-size: 32rpx; color: rgba(255,255,255,0.9); font-weight: 600; }
.countdown-time  { font-size: 48rpx; font-weight: 900; color: #fff; letter-spacing: 4rpx; }

/* ====== 底部三按钮 ====== */
.bottom-actions {
  position: fixed; bottom: 50rpx; left: 32rpx; right: 32rpx;
  display: flex; gap: 20rpx; z-index: 30;
}
.action-btn {
  flex: 1; height: 100rpx; border-radius: 20rpx; border: none;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 700;
}
.action-btn::after { border: none; }

/* 导航前往 → 珊瑚红 */
.nav-btn {
  background: #ff6b6b; color: #fff;
  box-shadow: 0 8rpx 28rpx rgba(255,107,107,0.5);
}
/* 联系电话 → 半透白 */
.contact-btn {
  background: rgba(255,255,255,0.15); color: #fff;
  border: 2rpx solid rgba(255,255,255,0.3);
}
/* 呼叫120 → 红字红框 */
.call120-btn {
  background: transparent; color: #ff4444;
  border: 2rpx solid #ff4444;
}

/* ====== 加载 ====== */
.loading-container {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; height: 100vh;
}
.loading-spinner {
  width: 80rpx; height: 80rpx;
  border: 6rpx solid rgba(255,255,255,0.15);
  border-top-color: #ff6b6b; border-radius: 50%;
  animation: spin 0.8s linear infinite; margin-bottom: 24rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 28rpx; color: rgba(255,255,255,0.6); }

.btn-text { font-size: 30rpx; font-weight: 700; color: inherit; }
