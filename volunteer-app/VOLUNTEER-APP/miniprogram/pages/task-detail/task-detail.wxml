<view class="container">
  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 任务详情 -->
  <block wx:if="{{!loading && task}}">
    <!-- 头部信息卡片 -->
    <view class="header-card">
      <view class="header-top">
        <view class="type-tag {{task.type}}">
          <text>{{task.typeText}}</text>
        </view>
        <view class="status-tag {{task.status}}">
          <text>{{task.statusText}}</text>
        </view>
      </view>
      <text class="task-title">{{task.title}}</text>
      <text class="task-desc">{{task.description || '暂无描述'}}</text>
    </view>

    <!-- 任务信息 -->
    <view class="info-card">
      <view class="info-row">
        <text class="info-label">📍 服务地点</text>
        <text class="info-value">{{task.location || '未知位置'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">🕐 发布时间</text>
        <text class="info-value">{{task.createTime}}</text>
      </view>
      <view class="info-row" wx:if="{{task.urgency}}">
        <text class="info-label">⚠️ 紧急程度</text>
        <text class="info-value urgency">{{task.urgency}}</text>
      </view>
      <view class="info-row" wx:if="{{task.needVisit !== undefined}}">
        <text class="info-label">🏠 是否上门</text>
        <text class="info-value">{{task.needVisit ? '需要上门服务' : '无需上门'}}</text>
      </view>
    </view>

    <!-- 发布者信息 -->
    <view class="publisher-card">
      <text class="card-section-title">发布者信息</text>
      <view class="publisher-row">
        <image class="publisher-avatar" src="{{publisher.avatar || '/images/logo.png'}}" mode="aspectFill" />
        <view class="publisher-info">
          <text class="publisher-name">{{publisher.nickname || '老人'}}</text>
          <text class="publisher-community">{{publisher.community || '未知社区'}}</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <view class="empty-wrap" wx:if="{{!loading && !task}}">
    <text class="empty-text">任务不存在或已删除</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{task}}">
    <button class="bar-btn accept-btn" wx:if="{{task.status === 'PENDING'}}" bindtap="handleAccept">
      接单
    </button>
    <button class="bar-btn contact-btn" wx:if="{{task.status === 'ACCEPTED'}}" bindtap="handleContact">
      联系老人
    </button>
    <button class="bar-btn complete-btn" wx:if="{{task.status === 'ACCEPTED'}}" bindtap="handleComplete">
      完成
    </button>
    <view class="bar-done" wx:if="{{task.status === 'COMPLETED'}}">
      <text class="done-icon">✅</text>
      <text class="done-text">任务已完成</text>
    </view>
  </view>

  <!-- 接单成功弹窗 -->
  <view class="modal-mask" wx:if="{{showContactModal}}" bindtap="closeModal"></view>
  <view class="modal-popup" wx:if="{{showContactModal}}">
    <text class="modal-title">接单成功</text>
    <text class="modal-desc">请及时联系老人确认服务详情</text>
    <view class="modal-phone-row">
      <text class="modal-label">老人手机号</text>
      <text class="modal-phone">{{task.contactPhone || '暂无'}}</text>
    </view>
    <view class="modal-actions">
      <button class="modal-btn call-btn" bindtap="makePhoneCall">拨打电话</button>
      <button class="modal-btn close-btn" bindtap="closeModal">知道了</button>
    </view>
  </view>
</view>
